[
    /// Vscode
    { "key": "ctrl+-",                 "command": "editor.action.fontZoomOut" },
    { "key": "ctrl+=",                 "command": "editor.action.fontZoomIn" },
    { "key": "ctrl+0",                 "command": "editor.action.fontZoomReset" },
    { "key": "ctrl+f",                 "command": "search.action.openNewEditor" },
    { "key": "ctrl+numpad_add",        "command": "editor.action.fontZoomIn" },
    { "key": "ctrl+numpad_subtract",   "command": "editor.action.fontZoomOut" },
    { "key": "ctrl+numpad0",           "command": "editor.action.fontZoomReset" },
    { "key": "ctrl+shift+=",           "command": "editor.action.fontZoomIn" },
    { "key": "ctrl+shift+d",           "command": "editor.action.copyLinesDownAction" },
    { "key": "f1",                     "command": "editor.action.showHover" },
    { "key": "shift+f12",              "command": "workbench.action.toggleDevTools" },
    { "key": "shift+f5",               "command": "workbench.action.reloadWindow" },
    { "key": "f12",                    "command": "editor.action.peekDefinition" },
    { "key": "shift+f12",              "command": "editor.action.revealDefinition" },

    // Remove keybindings that clash with other stuff
    { "key": "ctrl+g",                 "command": "-workbench.action.gotoLine" },
    { "key": "ctrl+pagedown",          "command": "-workbench.action.nextEditor" },
    { "key": "ctrl+pageup",            "command": "-workbench.action.previousEditor" },
    { "key": "ctrl+shift+,",           "command": "-editor.action.inPlaceReplace.up",        "when": "editorTextFocus && !editorReadonly" },
    { "key": "ctrl+shift+.",           "command": "-breadcrumbs.focusAndSelect",             "when": "breadcrumbsPossible" },
    { "key": "ctrl+shift+.",           "command": "-editor.action.inPlaceReplace.down",      "when": "editorTextFocus && !editorReadonly" },
    { "key": "ctrl+shift+tab",         "command": "-workbench.action.openPreviousRecentlyUsedEditorInGroup" },
    { "key": "ctrl+tab",               "command": "-workbench.action.openNextRecentlyUsedEditorInGroup" },
    { "key": "ctrl+shift+d",           "command": "-workbench.view.debug" },
    { "key": "ctrl+shift+d",           "command": "-activitusbar.showDebugView" },

    // Remove keybindgs I don't use
    { "key": "ctrl+,",                 "command": "-workbench.action.openSettings" },
    { "key": "ctrl+[",                 "command": "-editor.action.outdentLines",             "when": "editorTextFocus && !editorReadonly" },
    { "key": "ctrl+]",                 "command": "-editor.action.indentLines",              "when": "editorTextFocus && !editorReadonly" },
    { "key": "ctrl+m",                 "command": "-editor.action.toggleTabFocusMode" },
    { "key": "ctrl+q",                 "command": "-workbench.action.quit" },
    { "key": "ctrl+shift+.",           "command": "-breadcrumbs.toggleToOn" },
    { "key": "ctrl+w",                 "command": "-workbench.action.closeWindow",           "when": "!editorIsOpen && !multipleEditorGroups" },
    { "key": "ctrl+shift+w",           "command": "-workbench.action.closeWindow" },
    { "key": "f11",                    "command": "-workbench.action.toggleFullScreen" },

    // Tab navigation
    { "key": "ctrl+shift+tab",         "command": "workbench.action.previousEditorInGroup" },
    { "key": "ctrl+tab",               "command": "workbench.action.nextEditorInGroup" },
    { "key": "ctrl+alt+left",          "command": "workbench.action.focusLeftGroup" },
    { "key": "ctrl+alt+right",         "command": "workbench.action.focusRightGroup" },
    { "key": "ctrl+shift+alt+left",    "command": "workbench.action.moveEditorToLeftGroup" },
    { "key": "ctrl+shift+alt+right",   "command": "workbench.action.moveEditorToRightGroup" },

    /// Dance
    { "key": "escape",       "command": "-dance.macros.record.stop" },
    { "key": "escape",       "command": "-dance.set.normal" },
    { "key": "escape",       "command": "macros.dance.normal", "when": "editorTextFocus" },
    // { "key": "enter",        "command": "dance.set.insert", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "q",            "command": "-dance.macro.play" },
    { "key": "shift+q",      "command": "-dance.macro.record.start" },
    { "key": "q",            "command": "dance.select.word.previous", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+q",      "command": "dance.select.word.previous.extend", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "alt+q",        "command": "macros.dance.select.partWord.previous", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+shift+q",  "command": "macros.dance.select.partWord.previous.extend", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+w",        "command": "macros.dance.select.partWord", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+shift+w",  "command": "macros.dance.select.partWord.extend", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+e",        "command": "macros.dance.select.partWord", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+shift+e",  "command": "macros.dance.select.partWord.extend", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "d",            "command": "-dance.delete.yank" },
    { "key": "alt+d",        "command": "-dance.delete.noYank" },
    { "key": "c",            "command": "-dance.delete.insert.yank" },
    { "key": "alt+c",        "command": "-dance.delete.insert.noYank" },
    { "key": "d",            "command": "deleteRight", "when": "editorTextFocus && !editorHasSelection && dance.mode == 'normal'" },
    { "key": "d",            "command": "dance.delete.noYank", "when": "editorTextFocus && editorHasSelection && dance.mode == 'normal'" },
    { "key": "alt+d",        "command": "dance.delete.yank", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "c",            "command": "dance.delete.insert.noYank", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+c",        "command": "dance.delete.insert.yank", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "o",            "command": "-dance.insert.newLine.below" },
    { "key": "shift+o",      "command": "-dance.insert.newLine.above" },
    { "key": "alt+o",        "command": "-dance.newLine.below" },
    { "key": "alt+shift+o",  "command": "-dance.newLine.above" },
    { "key": "o",            "command": "editor.action.insertLineAfter", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+o",      "command": "editor.action.insertLineBefore", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "shift+n",      "command": "-dance.search.next.add" },
    { "key": "alt+n",        "command": "-dance.search.previous" },
    { "key": "shift+n",      "command": "dance.search.previous", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+n",        "command": "dance.search.next.add", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "alt+6",        "command": "dance.macros.record.start", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+shift+6",  "command": "dance.macros.record.stop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+6",      "command": "dance.macros.play", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": ",",            "command": "dance.openMenu", "args": { "menu": "user" }, "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "b",            "command": "dance.openMenu", "args": {"menu": "buffer"}, "when": "editorTextFocus && dance.mode == 'normal'"},

    // Prevent keys with no bindings from inserting characters in normal mode
    { "key": "enter",        "command": "openReference", "when": "editorTextFocus && dance.mode == 'normal' && inReferenceSearchEditor" },
    { "key": "ctrl+enter",   "command": "openReferenceToSide", "when": "editorTextFocus && dance.mode == 'normal' && inReferenceSearchEditor" },
    { "key": "enter",        "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal' && !inReferenceSearchEditor" },
    { "key": "backspace",    "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "\\",           "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+d",      "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "v",            "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+v",      "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+2",      "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+3",      "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+6",      "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "-",            "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "=",            "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+=",      "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "'",            "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+'",      "command": "macros.noop", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "pageup",       "command": "macros.scroll.up.halfPage" },
    { "key": "pagedown",     "command": "macros.scroll.down.halfPage" },
    { "key": "shift+pageup", "command": "macros.scroll.up.halfPage.select" },
    { "key": "shift+pagedown", "command": "macros.scroll.down.halfPage.select" },

    { "key": "ctrl+v",       "command": "-dance.tmp.normal" },
    { "key": "ctrl+v",       "command": "-dance.tmp.insert" },
    { "key": "ctrl+f",       "command": "-dance.down.page" },
    { "key": "ctrl+b",       "command": "-dance.up.page" },
    { "key": "ctrl+u",       "command": "-dance.up.halfPage" },
    { "key": "ctrl+d",       "command": "-dance.down.halfPage" },
    { "key": "ctrl+shift+f", "command": "-dance.down.page" },
    { "key": "ctrl+shift+b", "command": "-dance.up.page" },
    { "key": "ctrl+shift+u", "command": "-dance.up.halfPage" },
    { "key": "ctrl+shift+d", "command": "-dance.down.halfPage" },

    { "key": "ctrl+space",   "command": "-editor.action.triggerSuggest"},
    { "key": "ctrl+space",   "command": "editor.action.triggerSuggest", "when": "dance.mode == 'insert' && editorHasCompletionItemProvider && textInputFocus && !editorReadonly" },

    { "key": "ctrl+f",       "command": "-actions.find" },
]
