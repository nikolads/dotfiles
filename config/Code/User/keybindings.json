[
    { "key": "shift+f5",               "command": "workbench.action.reloadWindow" },
    { "key": "shift+f12",              "command": "workbench.action.toggleDevTools" },
    { "key": "f1",                     "command": "editor.action.showHover" },
    { "key": "ctrl+shift+d",           "command": "editor.action.copyLinesDownAction", "when": "editorTextFocus"  },
    { "key": "ctrl+shift+=",           "command": "editor.action.fontZoomIn" },
    { "key": "ctrl+numpad0",           "command": "editor.action.fontZoomReset" },
    { "key": "ctrl+numpad_subtract",   "command": "editor.action.fontZoomOut" },
    { "key": "ctrl+numpad_add",        "command": "editor.action.fontZoomIn" },
    { "key": "ctrl+0",                 "command": "editor.action.fontZoomReset" },
    { "key": "ctrl+=",                 "command": "editor.action.fontZoomIn" },
    { "key": "ctrl+-",                 "command": "editor.action.fontZoomOut" },

    // Remove keybindings that clash with other stuff
    { "key": "ctrl+g",                 "command": "-workbench.action.gotoLine" },
    { "key": "ctrl+pagedown",          "command": "-workbench.action.nextEditor" },
    { "key": "ctrl+pageup",            "command": "-workbench.action.previousEditor" },
    { "key": "ctrl+shift+,",           "command": "-editor.action.inPlaceReplace.up",        "when": "editorTextFocus && !editorReadonly" },
    { "key": "ctrl+shift+.",           "command": "-breadcrumbs.focusAndSelect",             "when": "breadcrumbsPossible" },
    { "key": "ctrl+shift+.",           "command": "-editor.action.inPlaceReplace.down",      "when": "editorTextFocus && !editorReadonly" },
    { "key": "ctrl+shift+tab",         "command": "-workbench.action.openPreviousRecentlyUsedEditorInGroup" },
    { "key": "ctrl+tab",               "command": "-workbench.action.openNextRecentlyUsedEditorInGroup" },

    // Remove keybindgs I don't use
    { "key": "ctrl+[",                 "command": "-editor.action.outdentLines",             "when": "editorTextFocus && !editorReadonly" },
    { "key": "ctrl+]",                 "command": "-editor.action.indentLines",              "when": "editorTextFocus && !editorReadonly" },
    { "key": "ctrl+q",                 "command": "-workbench.action.quit" },
    { "key": "ctrl+shift+.",           "command": "-breadcrumbs.toggleToOn" },
    { "key": "ctrl+w",                 "command": "-workbench.action.closeWindow",           "when": "!editorIsOpen && !multipleEditorGroups" },
    { "key": "f11",                    "command": "-workbench.action.toggleFullScreen" },

    // Tab navigation
    { "key": "alt+w ctrl+down",        "command": "workbench.action.moveEditorToBelowGroup" },
    { "key": "alt+w ctrl+left",        "command": "workbench.action.moveEditorToLeftGroup" },
    { "key": "alt+w ctrl+right",       "command": "workbench.action.moveEditorToRightGroup" },
    { "key": "alt+w ctrl+shift+down",  "command": "workbench.action.moveActiveEditorGroupDown" },
    { "key": "alt+w ctrl+shift+left",  "command": "workbench.action.moveActiveEditorGroupLeft" },
    { "key": "alt+w ctrl+shift+right", "command": "workbench.action.moveActiveEditorGroupRight" },
    { "key": "alt+w ctrl+shift+up",    "command": "workbench.action.moveActiveEditorGroupUp" },
    { "key": "alt+w ctrl+up",          "command": "workbench.action.moveEditorToAboveGroup" },
    { "key": "alt+w down",             "command": "workbench.action.focusBelowGroup" },
    // { "key": "alt+w h",                "command": "workbench.action.splitEditorDown" },
    { "key": "alt+w left",             "command": "workbench.action.focusLeftGroup" },
    { "key": "alt+w h",                "command": "workbench.action.focusLeftGroup" },
    { "key": "alt+w right",            "command": "workbench.action.focusRightGroup" },
    { "key": "alt+w l",                "command": "workbench.action.focusRightGroup" },
    { "key": "alt+w shift+down",       "command": "workbench.action.moveEditorToBelowGroup" },
    { "key": "alt+w shift+left",       "command": "workbench.action.moveEditorToLeftGroup" },
    { "key": "alt+w shift+right",      "command": "workbench.action.moveEditorToRightGroup" },
    { "key": "alt+w shift+up",         "command": "workbench.action.moveEditorToAboveGroup" },
    { "key": "alt+w up",               "command": "workbench.action.focusAboveGroup" },
    // { "key": "alt+w v",                "command": "workbench.action.splitEditorRight" },
    { "key": "ctrl+shift+tab",         "command": "workbench.action.previousEditorInGroup" },
    { "key": "ctrl+tab",               "command": "workbench.action.nextEditorInGroup" },

    // Dance
    { "key": "shift+q",      "command": "-dance.macro.record.start" },
    { "key": "q",            "command": "-dance.macro.play" },
    { "key": "ctrl+d",       "command": "-dance.down.halfPage" },
    { "key": "q",            "command": "dance.select.word.previous", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+q",      "command": "dance.select.word.previous.extend", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+q",        "command": "dance.select.word.alt.previous", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "shift+alt+q",  "command": "dance.select.word.alt.previous.extend", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "d",            "command": "-dance.delete.yank" },
    { "key": "alt+d",        "command": "-dance.delete.noYank" },
    { "key": "c",            "command": "-dance.delete.insert.yank" },
    { "key": "alt+c",        "command": "-dance.delete.insert.noYank" },
    { "key": "d",            "command": "deleteRight", "when": "editorTextFocus && !editorHasSelection && dance.mode == 'normal'" },
    { "key": "d",            "command": "dance.delete.noYank", "when": "editorTextFocus && editorHasSelection && dance.mode == 'normal'" },
    { "key": "alt+d",        "command": "dance.delete.yank", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "c",            "command": "dance.delete.insert.noYank", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+c",        "command": "dance.delete.insert.yank", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "shift+n",      "command": "-dance.search.next.add" },
    { "key": "alt+n",        "command": "-dance.search.previous" },
    { "key": "shift+n",      "command": "dance.search.previous", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": "alt+n",        "command": "dance.search.next.add", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "alt+o",        "command": "-dance.newLine.below" },

    { "key": ", s",          "command": "editor.action.sortLinesAscending", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": ", shift+s",    "command": "editor.action.sortLinesDescending", "when": "editorTextFocus && dance.mode == 'normal'" },
    { "key": ", q",          "command": "macros.compareNdcXml", "when": "editorTextFocus && dance.mode == 'normal'" },

    { "key": "ctrl+v",       "command": "-dance.tmp.normal" },
    { "key": "ctrl+v",       "command": "-dance.tmp.insert" },
    { "key": "ctrl+f",       "command": "-dance.down.page" },
    { "key": "ctrl+b",       "command": "-dance.up.page" },
    { "key": "ctrl+u",       "command": "-dance.up.halfPage" },
    { "key": "ctrl+d",       "command": "-dance.down.halfPage" },
    { "key": "ctrl+shift+f", "command": "-dance.down.page" },
    { "key": "ctrl+shift+b", "command": "-dance.up.page" },
    { "key": "ctrl+shift+u", "command": "-dance.up.halfPage" },
    { "key": "ctrl+shift+d", "command": "-dance.down.halfPage" },
]
