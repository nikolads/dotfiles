{
    // VSCode settings
    "breadcrumbs.enabled": false,
    "breadcrumbs.filePath": "last",

    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.maxComputationTime": 0,
    "diffEditor.renderSideBySide": true,

    "editor.autoClosingBrackets": "never",
    "editor.autoClosingQuotes": "never",
    "editor.codeLens": false,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.cursorSurroundingLines": 999,
    "editor.dragAndDrop": false,
    "editor.fontSize": 12,
    "editor.minimap.enabled": false,
    "editor.minimap.renderCharacters": false,
    "editor.peekWidgetDefaultFocus": "editor",
    "editor.renderControlCharacters": true,
    "editor.renderIndentGuides": true,
    "editor.renderWhitespace": "none",
    "editor.rulers": [120],
    "editor.selectionHighlight": false,
    "editor.semanticHighlighting.enabled": true,
    "editor.wordWrapColumn": 120,

    "explorer.confirmDragAndDrop": false,
    "explorer.openEditors.visible": 0,

    "extensions.ignoreRecommendations": true,

    "files.associations": {
        "*.lalrpop": "rust",
        "*.ron": "rust",
        "*.toml": "toml",
    },
    "files.exclude": {
        "**/.git": true,
        "**/.hg": true,
        "**/target": true,
    },
    "files.hotExit": "onExitAndWindowClose",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,

    "git.autofetch": false,

    "html.autoClosingTags": false,

    "search.searchEditor.reusePriorSearchConfiguration": true,

    "update.mode": "none",

    "telemetry.enableCrashReporter": false,
    "telemetry.enableTelemetry": false,

    "terminal.integrated.drawBoldTextInBrightColors": false,
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.shell.linux": "/usr/bin/fish",

    "typescript.referencesCodeLens.enabled": false,

    "window.customMenuBarAltFocus": false,
    "window.menuBarVisibility": "hidden",
    "window.newWindowDimensions": "inherit",
    "window.restoreWindows": "none",
    "window.titleBarStyle": "native",
    "window.zoomLevel": 0,

    "workbench.activityBar.visible": false,
    "workbench.editor.enablePreview": false,
    "workbench.editor.pinnedTabSizing": "compact",
    "workbench.iconTheme": "vs-seti",
    "workbench.settings.openDefaultKeybindings": false,
    "workbench.settings.openDefaultSettings": false,
    "workbench.startupEditor": "none",
    "workbench.tree.renderIndentGuides": "always",

    "[elixir]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.wordBasedSuggestions": false,
        "editor.formatOnType": false,
        "editor.acceptSuggestionOnEnter": "on",
        "editor.trimAutoWhitespace": false,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true
    },
    "[haskell]": {
        "editor.tabSize": 2,
    },
    "[html]": {
        "editor.tabSize": 2,
    },
    "[latex]": {
        "editor.tabSize": 2,
        "editor.wordWrap": "bounded",
    },
    "[makefile]": {
        "editor.detectIndentation": false,
        "editor.insertSpaces": false
    },
    "[markdown]": {
        "editor.wordWrap": "bounded"
    },
    "[plaintext]": {
        "files.trimTrailingWhitespace": false,
    },

    // Extension settings

    "remote.extensionKind": {
        "gregoire.dance": ["ui"],
    },

    "activitusbar.views": [
        {"name": "explorer", "octicon": "file-text"},
        {"name": "search", "octicon": "search"},
        {"name": "references", "octicon": "references" },
        {"name": "scm", "octicon": "repo-forked"},
        {"name": "debug", "octicon": "bug"},
        {"name": "extensions", "octicon": "package"},
        {"name": ""},
    ],

    "C_Cpp.intelliSenseEngine": "Default",
    "C_Cpp.dimInactiveRegions": true,

    "dance.normalMode.cursorStyle": "block",
    "dance.normalMode.lineHighlight": "editor.danceLineHighlightBackground",
    "dance.normalMode.lineNumbers": "on",
    "dance.selectionBehavior": "caret",
    "dance.menus": {
        "user": {
            "items": {
                "s": { "text": "sort asc", "command": "editor.action.sortLinesAscending" },
                "S": { "text": "sort desc", "command": "editor.action.sortLinesDescending" },
                "z": { "text": "word wrap", "command": "editor.action.toggleWordWrap" },
                "/": { "text": "comment line", "command": "editor.action.commentLine" },

                // temporary
                "a": { "text": "select args", "command": "macros.selectArgs" },
                "d": { "text": "copy & comment", "command": "macros.copyLinesDown.comment" },
            }
        },
        "buffer": {
            "items": {
                "d": {
                    "text": "close",
                    "command": "workbench.action.closeActiveEditor",
                },
                "D": {
                    "text": "close all",
                    "command": "workbench.action.closeAllEditors",
                },
                "h": {
                    "text": "focus left group",
                    "command": "workbench.action.focusLeftGroup",
                },
                "l": {
                    "text": "focus right group",
                    "command": "workbench.action.focusRightGroup",
                },
                "H": {
                    "text": "move to left group",
                    "command": "workbench.action.moveEditorToLeftGroup",
                },
                "L": {
                    "text": "move to right group",
                    "command": "workbench.action.moveEditorToRightGroup",
                },
                "o": {
                    "text": "switch header/source",
                    "command": "C_Cpp.SwitchHeaderSource",
                },
                "s": {
                    "text": "settings",
                    "command": "workbench.action.openSettingsJson",
                },
                "k": {
                    "text": "keybindings",
                    "command": "workbench.action.openGlobalKeybindingsFile",
                },
                "S": {
                    "text": "settings (default)",
                    "command": "workbench.action.openRawDefaultSettings",
                },
                "K": {
                    "text": "keybindings (default)",
                    "command": "workbench.action.openDefaultKeybindingsFile",
                },
            }
        },
    },

    "gruvboxMaterial.darkContrast": "soft",
    "gruvboxMaterial.darkPalette": "material",
    "gruvboxMaterial.darkSelection": "green",
    "gruvboxMaterial.darkWorkbench": "flat",

    "julia.enableTelemetry": false,

    "languageServerHaskell.hieExecutablePath": "/usr/bin/hie-wrapper",

    "latex-workshop.view.pdf.viewer": "tab",

    "macros": {
        "noop": [],

        // Copy line down and comment out the original line
        "copyLinesDown.comment": [
            "editor.action.addCommentLine",
            "editor.action.copyLinesDownAction",
            "editor.action.removeCommentLine",
        ],

        "scroll.up.halfPage": [
            {"command": "cursorMove", "args": {"to": "up", "by": "wrappedLine", "value": 30}},
        ],

        "scroll.down.halfPage": [
            {"command": "cursorMove", "args": {"to": "down", "by": "wrappedLine", "value": 30}},
        ],

        "scroll.up.halfPage.select": [
            {"command": "cursorMove", "args": {"to": "up", "by": "wrappedLine", "value": 30, "select": true}},
        ],

        "scroll.down.halfPage.select": [
            {"command": "cursorMove", "args": {"to": "down", "by": "wrappedLine", "value": 30, "select": true}},
        ],

        "selectArgs": [
            {"command": "dance.objects.performSelection", "args": {"object": "parens", "action": "select", "inner": true}},
            {"command": "dance.split", "args": {"input": ",\\s*"}},
        ],

        "dance.normal": [
            "closeDirtyDiff",
            "closeParameterHints",
            "closeReferenceSearch",
            "hideSuggestWidget",
            "dance.set.normal",
        ],

        "dance.select.partWord": [
            "dance.selections.reduce",
            "cursorWordPartRightSelect",
        ],
        "dance.select.partWord.extend": [
            "cursorWordPartRightSelect",
        ],
        "dance.select.partWord.previous": [
            "dance.selections.reduce",
            "cursorWordPartLeftSelect",
        ],
        "dance.select.partWord.previous.extend": [
            "cursorWordPartLeftSelect",
        ],

    },

    "rust-analyzer.assist.importMergeBehaviour": "last",
    "rust-analyzer.inlayHints.chainingHints": false,
    "rust-analyzer.inlayHints.parameterHints": false,
    "rust-analyzer.inlayHints.typeHints": false,
    "rust-analyzer.updates.channel": "stable",

    "trailing-spaces.highlightCurrentLine": false,

    "xmlTools.enableXmlTreeView": false,
    "xmlTools.splitXmlnsOnFormat": false,

    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {"scope": "storage", "settings": {"fontStyle": ""}},
            {"scope": "meta", "settings": {"fontStyle": ""}},
        ],
        "[Gruvbox Material Dark]": {
            "textMateRules": [
                {"scope": "source", "settings": {"foreground": "#bfac8a"}},
                {"scope": "variable", "settings": {"foreground": "#bfac8a"}},
                {"scope": "punctuation", "settings": {"foreground": "#bfac8a" }},
                {"scope": "meta.function-call.c", "settings": {"foreground": "#bfac8a" }},

                {"scope": "keyword.operator", "settings": {"foreground": "#928374" }},
                {"scope": "punctuation.brackets.angle.rust", "settings": {"foreground": "#928374" }},
                {"scope": "punctuation.semi", "settings": {"foreground": "#928374" }},
                {"scope": "punctuation.comma", "settings": {"foreground": "#928374" }},
                {"scope": "storage.modifier.reference", "settings": {"foreground": "#928374" }},
                {"scope": "storage.modifier.pointer", "settings": {"foreground": "#928374" }},

                {"scope": "constant.character.escape.cpp", "settings": {"foreground": "#a9b665"}},
                {"scope": "keyword.other.using.directive.cpp", "settings": {"foreground": "#ea6962" }},
                {"scope": "punctuation.definition.string.begin.cpp", "settings": {"foreground": "#d8a657" }},
                {"scope": "punctuation.definition.string.end.cpp", "settings": {"foreground": "#d8a657" }},
                {"scope": "storage.type.built-in.primitive.cpp", "settings": {"foreground": "#e78a4e" }},
                {"scope": "storage.type.namespace.directive.cpp", "settings": {"foreground": "#ea6962" }},
                {"scope": "storage.type.struct.cpp", "settings": {"foreground": "#ea6962" }},
                {"scope": "string.quoted.double.cpp", "settings": {"foreground": "#d8a657" }},
                {"scope": "string.quoted.double.include.cpp", "settings": {"foreground": "#d8a657" }},
                {"scope": "string.quoted.other.lt-gt.include.cpp", "settings": {"foreground": "#d8a657" }},
                {"scope": "string.quoted.single.cpp", "settings": {"foreground": "#d8a657" }},
                {"scope": "storage.type.namespace.definition.cpp", "settings": {"foreground": "#ea6962" }},

                {"scope": "storage.modifier", "settings": {"foreground": "#ea6962" }},
                {"scope": "storage.type.rust", "settings": {"foreground": "#ea6962" }},
                {"scope": "entity.name.function", "settings": {"foreground": "#7daea3" }},
                {"scope": "entity.name.function.macro", "settings": {"foreground": "#ea6962" }},
                {"scope": "entity.name.type", "settings": {"foreground": "#e78a4e" }},
            ],
        }
    },

    "editor.semanticTokenColorCustomizations": {
        "[Gruvbox Material Dark]": {
            "rules": {
                "interface": "#ea6962",
                "macro": "#d3869b",
                "macro:rust": "#ea6962",

                "keyword": "#ea6962",

                "namespace": "#89b482",
                "variable": "#bfac8a",
                "property": "#bfac8a",
                "parameter": "#bfac8a",
                "enumMember": "#bfac8a",

                // "punctuation": "#928374",
                "operator": "#928374",

                "type": "#e78a4e",
                "builtinType": "#e78a4e",
                "struct": "#e78a4e",
                "class": "#e78a4e",
                "enum": "#e78a4e",

                "function": "#7daea3",
                "method": "#7daea3",

                "*.constant": "#d3869b",
                "boolean": "#d3869b",
                "string": "#d8a657",

                "attribute": "#d3869b",
                "function.attribute": "#d3869b",
                "function.declaration": "#a9b665",
                "variable.declaration": "#a9b665",
            },
        }
    },

    "workbench.colorCustomizations": {
        "[Solarized Light Improved]": {
            "editor.dance.lineHighlightBackground": "#797d6428",
        },
        "[Solarized Dark Improved]": {
            "editor.dance.lineHighlightBackground": "#105a6b28",
        },
        "[Gruvbox Material Dark]": {
            "editor.foreground": "#bfac8a", // original #d4be98
            "editorCursor.foreground": "#bfac8a",
            "editor.lineHighlightBackground": "#32302f",
            "editor.danceLineHighlightBackground": "#403c3a70",
        },
    },

    // Automatically added
    "git.ignoreLegacyWarning": true,
    "editor.largeFileOptimizations": false,
    "workbench.colorTheme": "Gruvbox Material Dark",
}
